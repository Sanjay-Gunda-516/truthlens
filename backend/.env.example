# TruthLens — Environment Variables
# ─────────────────────────────────
# Copy this file:  cp .env.example .env
# Fill in your values. NEVER commit .env to git.

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://truthlens:truthlens_password@localhost:5432/truthlens_db

# JWT secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-random-256-bit-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI — only needed for Phase 2 upgrade
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
